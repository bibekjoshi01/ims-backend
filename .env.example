# App Settings
# Set to 'True' for development, 'False' for production
DEBUG=True
# Use a strong secret in production (do not commit the real secret)
SECRET_KEY=dev-secret
# Comma-separated list of allowed hosts (e.g. example.com,localhost)
DJANGO_ALLOWED_HOSTS=.localhost,.127.0.0.1

# CORS settings
# Set to 'True' to allow all origins (convenient for dev)
CORS_ALLOW_ALL_ORIGINS=True
# Comma-separated allowed origins when CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=

# Database (Postgres)
DB_NAME=operon_db
DB_USER=postgres
DB_PASSWORD=postgres_password
DB_HOST=localhost
DB_PORT=5432

# JWT / Authentication
# Number of days for access token lifetime (integer)
ACCESS_TOKEN_TIME=7
# Number of days for refresh token lifetime (integer)
REFRESH_TOKEN_TIME=10

# Upload limits
# Max image upload size in bytes (default 6291456 = 6 MB)
IMAGE_MAX_UPLOAD_SIZE=6291456

# Redis (used for cache/session/celery as configured)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# Notes:
# - Keep this file in source control as an example. Do NOT store real secrets here.
# - Create a real '.env' with production values and keep it secret (e.g. via environment or secret manager).
